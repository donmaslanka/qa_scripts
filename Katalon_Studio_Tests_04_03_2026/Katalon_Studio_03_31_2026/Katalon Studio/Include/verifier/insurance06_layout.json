    ],
    "termOnly": "Term life policy",
    "termInvestment": "Term life policy + investment of premium savings",
    "universalLife": "Universal life policy",
    "term": "Term",
    "termInv": "Term + Investment",
    "universal": "Universal",
    "endOfTerm": "In %years% years",
    "endOfPolicy": "In %years% years",
    "endOfLife": "At death",
    "rateOfReturn": "Rate of return %",
    "Premiums_MonthlyPremium1": "Monthly Premium 1",
    "Premiums_MonthlyPremium2": "Monthly Premium 2",
    "Premiums_MonthlyPremium3": "Monthly Premium 3",
    "lumpSum_Premium1": "Lump Sum Premium 1",
    "lumpSum_Premium2": "Lump Sum Premium 2",
    "lumpSum_Premium3": "Lump Sum Premium 3"
  },
  "glossaryItems": {
    "termlife": {
      "title": "Term life insurance",
      "definition": "A term life insurance policy provides a death benefit for a specific term, generally measured in years. Unlike permanent life, there is no buildup in cash value. When the coverage term expires, the policyholder buys a new term that matches his insurance needs. Since the policyholder is older, they will pay a larger premium to reflect their shorter life expectancy."
    },
    "surrendercharge": {
      "title": "Surrender charge",
      "definition": "A fee that you pay to cancel a life insurance policy or annuity contract. Also called a deferred sales charge or back-end load."
    },
    "premium": {
      "title": "Premium",
      "definition": "Insurance: The amount an insurance policyholder pays periodically to maintain insurance coverage. Premium: A price more than the face value of the bond."
    },
    "cashvalue": {
      "title": "Cash value",
      "definition": "A dollar value that is returned to an insurance policyholder if the policy is canceled."
    },
    "taxrates": {
      "title": "Tax rates",
      "definition": "The percentage of your taxable income that is owed to the state and federal governments. The tax rate increases as the taxable base amount increases. "
    },
    "savingsinterestrate": {
      "title": "Savings interest rate",
      "definition": "The yearly interest rate you earn on your savings."
    },
    "deathbenefit": {
      "title": "Death benefit",
      "definition": "An amount that is paid to the beneficiary of a life insurance policy upon the death of the insured. The amount may be a lump sum or an annuity."
    },
    "universallife": {
      "title": "Universal life insurance",
      "definition": "A type of permanent insurance that allows you to change your premiums and death benefit based on your needs and income. Your buildup in cash value is generally guaranteed a minimum rate of return based on money market yields but you cannot select your investments as you can with a variable life insurance policy."
    }
  },
  "help": [
    {
      "textLabel": "This tool compares rates of return for term and universal life insurance policies for three periods: "
    },
    {
      "textLabel": "Between now and the time that your term life policy expires."
    },
    {
      "textLabel": "Between now and the time that you receive full cash value for your universal life policy."
    },
    {
      "textLabel": "Between now and the time you die."
    },
    {
      "textLabel": "After-tax returns are provided for the following:"
    },
    {
      "textLabel": "The universal life policy."
    },
    {
      "textLabel": "The term life policy."
    },
    {
      "textLabel": "The term life policy, with premium savings invested in a taxable account."
    },
    {
      "textLabel": "Since universal life policy premiums are higher, the premium difference (the annual premium amount saved with a term life policy) is invested."
    },
    {
      "textLabel": "Generally, term life insurance policy premiums are initially lower than universal life premiums, which generally are constant. Term life premiums climb, however, past the premium amount for universal life policies as you age and have to renew your term life policy."
    }
  ],
  "chartTitles": [
    {
      "title": "Column chart of the after-tax rates of return of the term life policy, the term policy with premium savings invested in a taxable account, and the universal insurance policy at death."
    }
  ],
  "tableTitles": [
