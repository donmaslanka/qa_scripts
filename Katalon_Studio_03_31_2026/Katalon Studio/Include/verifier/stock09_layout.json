  "glossaryItems": {
    "foreignstock": {
      "title": "Foreign stock",
      "definition": "A stock that is issued by a company not registered in the U.S."
    },
    "rateofreturn": {
      "title": "Rate of return",
      "definition": "The percentage gain or loss on an investment expressed as a yearly rate."
    },
    "exchangerate": {
      "title": "Exchange rate",
      "definition": "The relationship of values between the currencies of two countries."
    },
    "currencyrisk": {
      "title": "Currency risk",
      "definition": "The risk that the value of your investment that is denominated in the currency of another country will rise or fall with the changes in the exchange rate between the countries."
    },
    "dividend": {
      "title": "Average quarterly dividends",
      "definition": "Dividends earned on a lot of shares, on average during a quarter."
    },
    "savingsinterestrate": {
      "title": "Savings interest rate",
      "definition": "The yearly interest rate you earn on your savings."
    }
  },
  "help": [
    {
      "textLabel": "This tool shows how a change in the <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#ExchangeRate\">exchange rate</a></span> of two countries affects the <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#RateOfReturn\">rate of return</a></span>, either positively or adversely, that you earn from investing in shares of stock of that country."
    },
    {
      "textLabel": "This risk of exchange rates potentially increasing or reducing the value of your foreign investment is called <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#CurrencyRisk\">currency risk</a></span>."
    },
    {
      "textLabel": "To buy shares of a <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#ForeignStock\">foreign stock</a></span>, you need to pay for them in the local currency. Start by calculating the exchange rate between the currency and the dollar on the day you buy the shares."
    },
    {
      "textLabel": "When the amount of the foreign currency required to be exchanged for local currency increases, your profits on an investment decrease if you sell. If the amount required decreases, your profits increase. In other words, when the dollar becomes more valuable, your return decreases. If the dollar weakens in relation to the foreign currency, your return increases."
    }
  ],
