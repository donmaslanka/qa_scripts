    "monthlyexpenses": {
      "title": "Monthly expenses",
      "definition": "Your monthly living expenses, less any expenses you might incur by going to work (such as fuel costs for commuting)."
    },
    "monthsofdisability": {
      "title": "Months of disability",
      "definition": "The number of months you might expect to be disabled or that you would require disability coverage."
    },
    "inflation": {
      "title": "Annual inflation rate",
      "definition": "A general increase in prices that you pay for goods and services, stated as a yearly rate."
    },
    "currentbonthlydisabilitycoverage": {
      "title": "Current monthly disability coverage",
      "definition": "Your current monthly dollar amount of disability coverage."
    },
    "monthsofdisabilitycoverage": {
      "title": "Months of disability coverage",
      "definition": "The months of disability coverage your curently have coverage for with an existing disability insurance plan."
    }
