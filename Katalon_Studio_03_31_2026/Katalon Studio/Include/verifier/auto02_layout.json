    "firstyeardepreciation": {
      "title": "First year's depreciation",
      "definition": "First year's depreciation is the dollar amount of depreciation expense. It is deducted from the purchase price to calculate the vehicle's residual, or book, value. Depreciation expense is highest in the early years of ownership, particularly for new vehicles. Depreciation of a vehicle with a high depreciation rate is greater than the expense of one with a low rate."
    },
    "depreciation": {
      "title": "Depreciation",
      "definition": "The decline in an asset's value over the course of its useful life due to wear and tear and obsolescence. "
    }
