  "glossaryItems": {
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "dividends": {
      "title": "Dividends",
      "definition": "A distribution of profits that companies and mutual funds make to shareholders. Dividends are taxed as long-term capital gains and are often paid to shareholders on a quarterly basis."
    },
    "dividend": {
      "title": "Average quarterly dividends",
      "definition": "Dividends earned on a lot of shares, on average during a quarter."
    },
    "dividendyield": {
      "title": "Dividend yield",
      "definition": "The dividend amount per share divided by the share price."
    },
    "reinvesting": {
      "title": "Reinvesting",
      "definition": "The act of investing dividends and capital gains that you receive from a company or mutual fund into additional shares of the stock or fund."
    }
  },
  "help": [
    {
      "textLabel": "This tool calculates your stock's <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#DividendYield\">dividend yield</a></span>, before and after taxes, based on its current share price and the amount of <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#Dividend\">average quarterly dividends</a></span> you receive. <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#Dividends\">Dividends</a></span> can be <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#Reinvesting\">reinvested</a></span> or spent."
    }
  ],
