  "glossaryItems": {
    "interestrate": {
      "title": "Interest rate",
      "definition": "The amount charged, expressed as a percentage of principal, by a lender to a borrower for the use of money."
    },
    "loanprincipal": {
      "title": "Loan principal",
      "definition": "The unpaid portion of the loan amount. Loan principal is amortized over the term of the loan so that the principal at the end of the term is zero."
    }
  },
  "help": [
    {
      "textLabel": "This tool calculates the additional monthly principal payment required to pay off a loan by a specific date and the resulting interest savings. The entire amount of additional payments is applied to amortizing the loan principal. Some mortgage loans may have a prepayment penalty. Check with your lender to verify whether your loan has such a penalty."
    }
  ],
