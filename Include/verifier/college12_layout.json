  "glossaryItems": {
    "weeklymealcount": {
      "title": "Number of meals covered each week",
      "definition": "Enter the number of meals the weekly plan entitles you to eat each week."
    },
    "estweeklymealsmissed": {
      "title": "Estimated meals missed weekly",
      "definition": "Enter the number of meals you estimate you will miss each week. Each meal that you miss increases the per-meal cost of the meal plan. The analyzer assumes the meals you miss are paid with cash."
    },
    "weeklymealplan": {
      "title": "Weekly meal plan",
      "definition": "A weekly meal plan assumes you pay for a fixed number of meals each week for a certain period."
    },
    "mealplancost": {
      "title": "Cost of meal plan",
      "definition": "Enter the total cost of the plan."
    },
    "forfeitedmealcount": {
      "title": "Estimated number of meals missed",
      "definition": "Enter the number of meals you estimate you will miss over the life of the block plan. Each meal that you miss increases the per-meal cost of the meal plan. The analyzer assumes the meals you miss are paid with cash."
    },
    "mealplanweeks": {
      "title": "Number of weeks of plan",
      "definition": "Enter the number of weeks that are included in the weekly meal plan."
    },
    "blockperiodmealcount": {
      "title": "Number of meals in block period",
      "definition": "Enter the number of meals the block plan entitles you to eat."
    },
    "campuscash": {
      "title": "Campus cash",
      "definition": "Campus cash is the extra amount you receive from your meal plan to spend freely. For example, if you buy a $1,000 plan, your school may charge $900 for the meals and give you $100 to spend in campus cash. Campus cash is often required to be spent within a network of on- and off-campus merchants. Campus cash is excluded from calculations of the per-meal cost."
    },
    "blockmealplan": {
      "title": "Block meal plan",
      "definition": "A block meal plan assumes you pay for a fixed number of meals."
    }
  },
  "help": [
    {
      "textLabel": "This tool helps you determine the average cost per meal for a meal plan. Many colleges and universities require students that reside on campus to register for a meal plan. Even if you are not required, it may be cheaper to buy a meal plan than to pay cash for your meals. Most sources of financial aid and tax-advantaged college savings plans consider meals a legitimate education-related expense."
    },
    {
      "textLabel": "Some of the questions you may ask about meal plans include:"
    },
    {
      "textLabel": "Can unused meals be rolled over and used in the next period?"
    },
    {
      "textLabel": "Are meal portions unlimited?"
    },
    {
      "textLabel": "What are the dining hours and when are meal times?"
    },
    {
      "textLabel": "What types and what merchants accept campus-cash?"
    },
    {
      "textLabel": "Is sales tax levied on the plan?"
    },
    {
      "textLabel": "Does the plan accommodate for special meals (e.g. ethnic or vegetarian)?"
    }
  ],
  "chartTitles": [
    {
      "title": "Column chart comparing the average cost per meal if no meals are missed, if the specified number of meals are missed, or all meals are paid for out-of-pocket."
    }
  ],
