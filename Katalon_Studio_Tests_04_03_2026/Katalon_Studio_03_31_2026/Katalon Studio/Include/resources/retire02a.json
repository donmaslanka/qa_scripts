  },
  {
    "verifyText": {
      "id": "lf_help_1",
      "value": "Save early, regularly, and stick to the plan. The sooner you start saving, the more time your money has to grow."
    }
  },
  {
    "verifyText": {
      "id": "lf_help_2",
      "value": "Keep working. Retire later to give your portfolio the chance to continue increasing in value for a few more years."
    }
  },
  {
    "verifyText": {
      "id": "lf_help_3",
      "value": "Put money into tax-advantaged accounts. Good options include traditional IRAs, Roth IRAs, Roth 401(k)s, and 401(k)s or similar employer-sponsored retirement plans."
    }
  },
  {
    "verifyText": {
      "id": "lf_help_4",
      "value": "Diversify your investment portfolio. The more diverse a portfolio, the safer it is."
    }
  },
  {
    "verifyText": {
      "id": "lf_help_5",
      "value": "Pay down higher interest debt like credit cards to free up more money for retirement plan contributions"
    }
  },
  {
    "verifyText": {
      "id": "lf_help_6",
      "value": "Purchase long-term care insurance to reduce medical expenses in retirement"
    }
  },
  {
    "verifyText": {
      "id": "lf_help_7",
