      "title": "Total monthly minimum loan payments",
      "definition": "Membership Rewards provides 0.25% cash back on the minimum scheduled payment amount made from another First Tech account to your First Tech consumer and/or HELOC loan(s), up to a maximum of $15 per month."
    },
    "monthlycardspending": {
      "title": "Monthly card spending",
      "definition": "Membership Rewards provides 0.50% cash back on all posted credit card purchases made on your First Tech credit card account, up to a maximum of $15 per month."
    },
    "averagesavingsbalance": {
      "title": "Average savings account balance",
      "definition": "At any given time, what is your typical savings account balance?"
    },
    "term": {
      "title": "Term",
      "definition": "The period of a loan, generally measured in years. "
    },
    "ftgrossincome": {
      "title": "Gross Income",
      "definition": "Please include all wages, and other sources of income such as investment and residential income before taxes."
    },
    "averagecheckingbalance": {
      "title": "Average checking account balance",
      "definition": "At any given time, what is your typical checking account balance?"
    },
    "streamingservicefeeschargedtocard": {
      "title": "Streaming service fees charged to card",
      "definition": "Membership Rewards provides reimbursement of monthly online streaming subscription services charged to the credit card account, up to a maximum of $10 per month."
    },
    "grossincome": {
      "title": "grossincome",
      "definition": "Please include all wages, and other sources of income such as investment and residential income before taxes."
    },
    "rentalincome": {
