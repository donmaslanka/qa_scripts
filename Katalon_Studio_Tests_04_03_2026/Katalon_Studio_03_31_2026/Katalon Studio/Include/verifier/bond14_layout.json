  "glossaryItems": {
    "couponrate": {
      "title": "Coupon rate",
      "definition": "The interest rate on a bond, stated as a percentage of the bond's face value. For example, a $1,000 bond that pays $60 in interest a year has a coupon rate of 6%."
    },
    "bondprice": {
      "title": "Bond price",
      "definition": "The current price of a bond in the market, as determined by supply and demand. Bond prices are usually stated as a percentage of their face value. For example, a $1,000 bond that is quoted at a price of 98.00 trades at $980."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "parvalue": {
      "title": "Par value",
      "definition": "The stated, or nominal, price of a bond or fixed deposit, such as a CD, when it matures. Also known as face value."
    },
    "maturity": {
      "title": "Maturity",
      "definition": "Loans: Maturity is the end of a loan term when the full amount of the loan is repaid in full to the lender. Bonds: Maturity is the date that the face value of the bond is repaid to investors."
    },
    "discount": {
      "title": "Discount",
      "definition": "A price that is less than the regular sale price. In bond investing, a discount is a bond price that is less than the par value of the bond. "
    },
    "corporatebonds": {
      "title": "Corporate bond",
      "definition": "Bonds issued by corporations to raise money for operations."
    },
    "munibonds": {
      "title": "Municipal bond",
      "definition": "States and municipalities issue municipal bonds, or muni bonds for short. Investors often buy muni bonds issued by the state or municipality in which they reside to derive the greatest income tax benefit."
    },
    "facevalue": {
      "title": "Face value",
      "definition": "The stated, or nominal, price of a bond or fixed deposit, such as a CD, when it matures. Also known as par value."
    },
    "rateofreturn": {
      "title": "Rate of return",
      "definition": "The percentage gain or loss on an investment expressed as a yearly rate."
    },
    "imputedinterest": {
      "title": "Imputed interest",
      "definition": "The amount of interest earned on a zero-coupon bond."
    },
    "ytm": {
      "title": "Yield-to-maturity",
      "definition": "The interest rate, or internal rate of return (IRR), that makes the cash inflows equal to the price you pay for the bond. Cash inflows are made up of coupon interest and the bond principal when the bond matures."
    },
    "zerocouponbond": {
      "title": "Zero-coupon bond",
      "definition": "A zero-coupon bond is sold at a large discount to par value that pays no coupon interest. As the bond approaches its maturity date, the price of the bond rises towards par value. This appreciation of a zero-coupon bond is called imputed interest. The IRS requires you to report imputed interest as taxable income unless you have earned it on a tax-exempt bond."
    },
    "bondtypes": {
      "title": "Bond types",
      "definition": "The four major types of bonds, as defined by category of issuers, are U.S. government, corporate, agency, and municipal bonds. U.S. government bonds include U.S. Treasury securities. Corporate bonds include those sold by private companies to raise funds. Agency bonds include those sold by government-sponsored enterprises, such as Ginnie Mae, Fannie Mae, and Freddie Mac. Municipal bonds include those sold by state and local governments."
    },
    "treasurysecurities": {
      "title": "Treasury securities",
      "definition": "Debt obligations of the U.S. government with a maturity of longer than 10 years. Also called a T-bond."
    },
    "marketinterestrate": {
      "title": "Market interest rate",
      "definition": "The interest rate for bonds with similar risk characteristics and terms to maturity to those of the bond you are selling."
    },
    "reinvesting": {
      "title": "Reinvesting",
      "definition": "The act of investing dividends and capital gains that you receive from a company or mutual fund into additional shares of the stock or fund."
    }
  },
  "help": [
    {
      "textLabel": "This tool compares two bond investments: buying a bond at a substantial <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#Discount\">discount</a></span> to <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#ParValue\">par value</a></span> and receiving no coupon (a <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#ZeroCouponBond\">zero-coupon bond</a></span>), and buying a bond with a coupon. Rates of return are provided for two periods: 1) the remaining term to <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#Maturity\">maturity</a></span>) (your <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#YTM\">yield to maturity</a></span>) and 2) the number of months until you sell the bonds. "
    },
    {
      "textLabel": "Depending on the types of bonds being compared, the taxes applied to coupon payments will vary. Treasury securities are exempt from state income taxes. Municipal bonds are exempt from federal income taxes. In some cases, muni bonds are also exempt from state income taxes. "
    },
    {
      "textLabel": "With a zero-coupon bond, you must report <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#ImputedInterest\">imputed interest</a></span> as income. As a result, your after-tax <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#RateOfReturn\">rate of return</a></span> on a zero-coupon bond may be lower."
    }
  ],
