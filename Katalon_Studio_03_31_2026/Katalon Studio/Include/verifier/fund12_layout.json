  "glossaryItems": {
    "rateofreturn": {
      "title": "Rate of return",
      "definition": "The percentage gain or loss on an investment expressed as a yearly rate."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "exchangerate": {
      "title": "Exchange rate",
      "definition": "The relationship of values between the currencies of two countries."
    },
    "dividends": {
      "title": "Dividends",
      "definition": "A distribution of profits that companies and mutual funds make to shareholders. Dividends are taxed as long-term capital gains and are often paid to shareholders on a quarterly basis."
    },
    "currencyrisk": {
      "title": "Currency risk",
      "definition": "The risk that the value of your investment that is denominated in the currency of another country will rise or fall with the changes in the exchange rate between the countries."
    },
    "capgain": {
      "title": "Capital gain",
      "definition": "An increase in the value of a capital asset that you own. The IRS defines a capital asset as almost everything you use for personal purposes or investment, including stocks and bonds, your home, personal property, and collectibles."
    },
    "growthratedividends": {
      "title": "Expected rate of growth in dividends",
      "definition": "Enter the annual rate of increase you predict for dividends. By definition, this figure will be much higher for an income fund than a growth fund."
    },
    "backendload": {
      "title": "Back-end load",
      "definition": "A fee you pay when you sell shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are selling."
    },
    "frontendload": {
      "title": "Front-end load",
      "definition": "A fee you pay when you buy shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are investing."
    }
  },
  "help": [
    {
      "textLabel": "This tool shows how a change in the <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#exchangeRate\">exchange rate</a></span> of two countries affects the <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#rateOfReturn\">rate of return</a></span>, either positively or adversely, that you earn from investing in shares of a mutual fund from that country."
    },
    {
      "textLabel": "This risk of exchange rates potentially increasing or reducing the value of your foreign investment is called <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#currencyRisk\">currency risk</a></span>."
    },
    {
      "textLabel": "To buy shares of a foreign mutual fund, you need to pay for them in the local currency. "
    },
    {
      "textLabel": "When the amount of the foreign currency required to be exchanged for local currency increases, your profits on an investment decrease if you sell. If the amount required decreases, your profits increase. In other words, when the dollar becomes more valuable, your return decreases. If the dollar weakens in relation to the foreign currency, your return increases."
    }
  ],
  "chartTitles": [
