  "labels": {
    "dataTableCategory": "Average Cost Per Year",
    "dataTableCategory2": "Monthly Payment",
    "title": "Which is better: a new or used vehicle?",
    "answer": "The used vehicle will cost you $4,542 less on average each year",
    "answer_same": "Considering financing, maintenance and other costs, the new vehicle purchased at a price of <span class='lf-bold'>%newPrice%</span> will cost you <span class='lf-bold'>the same</span> on average each year as the used vehicle purchased for <span class='lf-bold'>%usedPrice%</span>.",
