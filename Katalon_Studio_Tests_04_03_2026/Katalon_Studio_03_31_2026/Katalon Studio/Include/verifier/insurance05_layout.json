  "glossaryItems": {
    "premium": {
      "title": "Premium",
      "definition": "Insurance: The amount an insurance policyholder pays periodically to maintain insurance coverage. Premium: A price more than the face value of the bond."
    },
    "cashvalue": {
      "title": "Cash value",
      "definition": "A dollar value that is returned to an insurance policyholder if the policy is canceled."
    },
    "taxrates": {
      "title": "Tax rates",
      "definition": "The percentage of your taxable income that is owed to the state and federal governments. The tax rate increases as the taxable base amount increases. "
    },
    "savingsinterestrate": {
      "title": "Savings interest rate",
      "definition": "The yearly interest rate you earn on your savings."
    },
    "deathbenefit": {
      "title": "Death benefit",
      "definition": "An amount that is paid to the beneficiary of a life insurance policy upon the death of the insured. The amount may be a lump sum or an annuity."
    },
    "dividendsinsurancepolicy": {
      "title": "Dividends (insurance policy)",
      "definition": "A return of insurance premiums to the policyholder. If the investments that an insurance company makes perform better than expected, the insurer returns some of the previously paid premiums."
    }
  },
  "help": [
    {
      "textLabel": "This tool compares rates of return for term and whole life insurance policies for two periods:<div class=\"lf-help-ul-container\"><ul><li>Between now and the time that you receive full cash value for your whole life policy.</li><li>Between now and the time you die.</li></ul></div>After-tax returns are provided for the following:</br></br><div class=\"lf-help-ul-container\"><ul><li>The whole life policy.</li><li>The term life policy.</li><li>The term life policy, with premium savings invested in a taxable account.</li></ul></div>Since whole life policy premiums are higher, the premium difference (the annual premium amount saved with a term life policy) is invested.</br></br>Generally, term life insurance policy premiums are initially lower than whole life premiums, which generally are constant. Term life premiums climb, however, past the premium amount for whole life policies as you age and have to renew your term life policy.</br>"
    }
  ],
  "chartTitles": [
    {
