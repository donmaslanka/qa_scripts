  "labels": {
    "title": "What is my housing expense ratio?",
    "answer": "<h2 class='lf-graph-text'>Based on a gross monthly income of <span class='lf-bold'>$%result1%</span> and a monthly mortgage payment of <span class='lf-bold'>$%result2%</span> <span class='lf-bold'>your estimated housing expense ratio is %result3%%</span></h2>",
