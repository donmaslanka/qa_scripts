  "glossaryItems": {
    "movingexpenses": {
      "title": "Moving expenses",
      "definition": "Enter the amount you spend to move when you or your child heads off to college for the first time."
    },
    "pcandrelatedexpenses": {
      "title": "PC and related expenses",
      "definition": "Enter the amount you spend on a personal computer and peripheral equipment that you will use when you enter college."
    },
    "aveapplicationfee": {
      "title": "Average application fee",
      "definition": "Enter the average application fee for the colleges or universities you wish to attend. For example, if the application fees to College A and College B are $75 and $125, respectively, the average fee is $100."
    },
    "numberofcolleges": {
      "title": "Number of colleges",
      "definition": "Enter the number of colleges or universities you expect to visit and evaluate. In the input fields, below, enter the aggregate amount you expect to spend to visit all schools. For example, if you anticipate airfare to visit three schools to cost $1,500, enter $1,500 in the input field for airfare."
    },
    "admissionexamprepfees": {
      "title": "Admission exam preparation fees",
      "definition": "Fees for an entrance exam-preparation course offered by a commercial test-taking service. "
    },
    "furnitureandsupplies": {
      "title": "Furniture and supplies",
      "definition": "Enter the amount that you spend on furniture, bedding, and related supplies when you or your child heads off to college for the first time."
    },
    "admissionexamfees": {
      "title": "Admission exam fees",
      "definition": "Admission exam fees are the fees you pay to take the entrance exam for admission to college. The two primary entrance exams are the Scholarship Assessment Test (SAT) and American College Test (ACT). "
    }
  },
  "help": [
    {
      "textLabel": "This tool helps you budget for expenses that are directly related to the cost of getting ready to attend college. Many of these expenses are incurred in the 18 months or so prior to beginning college."
    }
  ],
  "chartTitles": [
