  "glossaryItems": {
    "cdamount": {
      "title": "CD amount",
      "definition": "CD amount is the amount you deposit to buy a certificate of deposit (CD). You deposit the face amount of a CD and are repaid the face amount at maturity. During the CD term, you collect interest at a fixed or variable interest rate. CDs are sold in denominations of $500 to $250,000."
    },
    "taxrates": {
      "title": "Tax rates",
      "definition": "The percentage of your taxable income that is owed to the state and federal governments. The tax rate increases as the taxable base amount increases. "
    },
    "cdinterestrate": {
      "title": "CD interest rate",
      "definition": "Enter the annual interest rate of your certificate of deposit (CD). This rate is called the simple interest rate. If interest is compounded, you will earn an annual percentage yield (APY) that is greater than the stated rate."
    },
    "cdcompoundingfrequency": {
      "title": "CD compounding frequency",
      "definition": "Enter the number of times in a year that interest on your certificate of deposit (CD) is compounded. Compounding increases the amount of interest you earn on a CD. For example, if the institution compounds interest every three months (quarterly) on a CD with a simple rate of 10%, your annual percentage yield (APY) is 10.38%. If compounded monthly, you earn 10.47%. If compounded daily, you earn 10.52%. For a $10,000 deposit, daily compounding adds up to an extra $52 in interest that you earn over the simple yield."
    },
    "cddepositterm": {
      "title": "CD deposit term",
      "definition": "CD deposit term is the period for which you deposit money in a certificate of deposit (CD). Most common deposit terms are three, six and 12 months. If you wish to redeem your CD before its maturity date, the financial institution that holds it will likely charge an early-redemption penalty."
    }
  },
  "help": [
    {
      "textLabel": "CD laddering is an investment strategy that involves spreading funds across multiple certificates of deposit (CDs) with different maturity dates.  Compared to investing in a single short term CD and rolling it over at maturity, CD laddering provides increased returns while creating access to funds periodically to reinvest or withdraw if funds are needed for an unexpected or planned expense.  "
    },
    {
      "textLabel": "CDs are time deposits that are guaranteed for up to $250,000 per depositor per institution by the U.S. Federal Deposit Insurance Corporation (FDIC). Because CDs are federally insured, they are considered relatively conservative investments. As a result, they pay a lower interest rate -- stated as an annual percentage yield (APY) -- than non-insured investments such as stocks and bonds."
    },
    {
      "textLabel": "This financial tool assumes that the short and medium term CDs are reinvested in the long term CD at maturity, with no changes to the interest rates specified. "
    }
  ],
  "chartTitles": [
