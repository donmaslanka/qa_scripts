  "glossaryItems": {
    "futuremonthlypayments": {
      "title": "Future monthly payments",
      "definition": "The amount you intend to pay on your credit card balance on a monthly basis. If your payments are less than the interest expense for the period, unpaid interest is added to your card balance. "
    },
    "futuremonthlycharges": {
      "title": "Future monthly charges",
      "definition": "The net amount you charge on your credit card on a monthly basis, deducting any returns that are credited to your card balance."
    },
    "futureinterestrates": {
      "title": "Future interest rates",
      "definition": "The future interest rate is your prediction of the magnitude of change in the interest rate used to price your loan. Future rates are assumed to change at the same rate every year."
    }
  },
  "help": [
    {
      "textLabel": "This tool estimates the amount of time to pay off a credit card balance based on a desired monthly payment or the payment required to pay off a balance by a desired timeframe. Regardless of payoff plan desired, the tool will also estimate the total interest paid and present additional monthly payment options for consideration."
    }
