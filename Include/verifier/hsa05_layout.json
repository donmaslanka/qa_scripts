  "glossaryItems": {
    "hsahealthplantype": {
      "title": "HSA Health Plan Type",
      "definition": "The health plan type you have influences the minimum deductable you must fulfill for your health plan to qualify as a high deductable health plan."
    },
    "hsaage": {
      "title": "Your Age",
      "definition": "Your age is used to determine the maximum amount you can contribute to your HSA. If you or your spouse is over 55, there is a catch up amount that is allowed. Refer to IRS Publication 969 for more information."
    },
    "healthcareexpenses": {
      "title": "Qualified Medical Expenses",
      "definition": "Qualified medical expenses are defined by IRS Publication 502."
    },
    "hsaannualrateofreturn": {
      "title": "Annual Rate of Return on your HSA account",
      "definition": "The return you expect to earn on the money in your HSA."
    },
    "hdhpdeductible": {
      "title": "High Deductible Health Plan Deductible",
      "definition": "A deductible is what you pay out of pocket before any insurance payments are applied to your care. A high deductible health plan is one where the deductible is over $1,650 for single coverage ($3,300 for family coverage) in 2025."
    }
  },
  "help": [
    {
      "textLabel": "This tool helps you figure out how much you should contribute to your HSA to meet a specific goal amount at retirement."
    },
    {
      "textLabel": "The return on your HSA is influenced by the investment decisions you make."
    },
    {
      "textLabel": "For IRS help concerning health savings accounts, refer to <a target=\"_blank\" href=\"https://www.irs.gov/publications/p969\">IRS Publication 969</a> and <a target=\"_blank\" href=\"https://www.irs.gov/publications/p502\">IRS Publication 502</a>."
    }
