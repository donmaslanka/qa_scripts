  "glossaryItems": {
    "MonthlyRent": {
      "title": "Monthly rent",
      "definition": "Include any property taxes, HOA fees, homeowner's insurance, renter's insurance, etc."
    },
    "OtherMonthlyPaymentsDTI": {
      "title": "Other monthly payments",
      "definition": "Include any alimony, child support and other recurring financial obligations.  However, monthly expenses such as utilities and groceries are not typically included in determining your DTI ratio."
    }
  },
  "help": [
    {
      "textLabel": "This tool calculates your debt-to-income (DTI) ratio or \"back-end ratio\". DTI is used by lenders to approve loan applicants. The debt-to-income ratio equals your combined monthly debt payments divided by gross monthly income."
    },
    {
      "textLabel": "Mortgage lenders regularly use a DTI ratio of 36% or lower as a guideline to approve home loans. DTI guidelines change over the course of the economic cycle. When the economy is strong, lenders tend to raise the ratio, making it easier to obtain a loan. When the economy is weak, lenders tend to lower the ratio, making it harder to obtain a loan. A weaker economy leads to lower interest rates, which makes it somewhat easier to qualify."
    }
  ],
