  "glossaryItems": {
    "rateofreturn": {
      "title": "Rate of return",
      "definition": "The percentage gain or loss on an investment expressed as a yearly rate."
    },
    "dividendincome": {
      "title": "Dividend income",
      "definition": "A distribution of profits that companies or mutual funds make to shareholders."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "dividends": {
      "title": "Dividends",
      "definition": "A distribution of profits that companies and mutual funds make to shareholders. Dividends are taxed as long-term capital gains and are often paid to shareholders on a quarterly basis."
    },
    "dividend": {
      "title": "Average quarterly dividends",
      "definition": "Dividends earned on a lot of shares, on average during a quarter."
    },
    "savingsinterestrate": {
      "title": "Savings interest rate",
      "definition": "The yearly interest rate you earn on your savings."
    },
    "reinvesting": {
      "title": "Reinvesting",
      "definition": "The act of investing dividends and capital gains that you receive from a company or mutual fund into additional shares of the stock or fund."
    },
    "brokeragecommission": {
      "title": "Brokerage commission",
      "definition": "The fees that you pay a broker to buy or sell stocks, bonds, or other securities. They are also called transaction fees, trading fees, brokerage fees, or simply, commissions."
    }
  },
  "help": [
    {
      "textLabel": "This tool calculates how <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#BrokerageCommission\">brokerage fees</a></span> you pay to buy and sell shares of stock reduce the <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#RateOfReturn\">rate of return</a></span> on a stock investment."
    },
    {
      "textLabel": "The tool assumes you sell your shares at the current share price. <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#Dividends\">Dividends</a></span> that you have received while owning the shares are assumed to have been <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#Reinvesting\">reinvested</a></span> at the rate you specify or spent. "
    }
  ],
