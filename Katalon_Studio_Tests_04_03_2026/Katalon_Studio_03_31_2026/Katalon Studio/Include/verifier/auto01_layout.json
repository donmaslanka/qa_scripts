  "glossaryItems": {
    "loanterm": {
      "title": "Loan term",
      "definition": "The length, or period, of a loan. It is usually measured in years. "
    },
    "firstyeardepreciation": {
      "title": "First year's depreciation",
      "definition": "First year's depreciation is the dollar amount of depreciation expense. It is deducted from the purchase price to calculate the vehicle's residual, or book, value. Depreciation expense is highest in the early years of ownership, particularly for new vehicles. Depreciation of a vehicle with a high depreciation rate is greater than the expense of one with a low rate."
    },
    "taxrates": {
      "title": "Tax rates",
      "definition": "The percentage of your taxable income that is owed to the state and federal governments. The tax rate increases as the taxable base amount increases. "
    },
    "savingsinterestrate": {
      "title": "Savings interest rate",
      "definition": "The yearly interest rate you earn on your savings."
    },
    "downpayment": {
      "title": "Down payment",
      "definition": "The cash you deposit towards the purchase of home, car, etc. The larger the down payment, the less you are required to borrow."
    },
    "depreciation": {
      "title": "Depreciation",
      "definition": "The decline in an asset's value over the course of its useful life due to wear and tear and obsolescence. "
    }
  },
  "help": [
    {
      "textLabel": "The decision to buy a new vehicle instead of a used one requires that you consider the following:"
    },
    {
      "textLabel": "<i>Purchase price.</i> A new vehicle will clearly cost you more than a used vehicle of the same make and model. The extent to which the new or used car will drop in value is based on the depreciation rate chosen - average, high or low."
    },
    {
      "textLabel": "<i>Depreciation.</i> Some vehicles depreciate faster than others do. The slower the depreciation rate of the vehicle, the higher its resale value."
    },
    {
      "textLabel": "<i>Operating costs.</i> A used vehicle is likely to require more maintenance and repair than a new one. Also, fuel consumption may be less efficient."
    },
    {
      "textLabel": "<i>Years of ownership.</i> The longer you own the vehicle, the lower the average annual cost, as acquisition costs are spread out over more years."
    },
    {
      "textLabel": "<i>Financing cost.</i> Interest rates for new vehicle loans are generally lower than for used vehicle loans."
    }
  ],
