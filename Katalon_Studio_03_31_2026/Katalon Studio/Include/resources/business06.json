    "verifyText": {
      "id": "lf_help_0",
      "value": "When you buy goods on credit, a supplier may offer you a discount if you pay early. This incentive is called a discount on trade credit. For example, a supplier may offer you trade terms of \"2% 10 net 30.\" These credit terms offer you a 2% discount if you pay within 10 days of the invoice. Otherwise, payment of the unpaid balance is due within 30 days of the invoice."
    }
  },
  {
    "verifyText": {
      "id": "lf_help_1",
      "value": "You should take advantage of the trade discount if the annual interest rate on the trade discount is higher than your cost of borrowing."
