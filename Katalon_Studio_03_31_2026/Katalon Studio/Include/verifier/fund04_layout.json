  "glossaryItems": {
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "investreturn": {
      "title": "Investment return",
      "definition": "The gain or loss on an investment, stated as an annual percentage rate."
    },
    "backendload": {
      "title": "Back-end load",
      "definition": "A fee you pay when you sell shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are selling."
    },
    "noloadmutualfund": {
      "title": "No-load mutual fund",
      "definition": "A mutual fund that does not charge an initial fee, or load, when you buy shares."
    },
    "fees12b1": {
      "title": "12(b)-1 fees",
      "definition": "Named for the SEC rule that permits them, 12(b)-1 fees are paid every year to the mutual fund for marketing and distribution costs. They are generally between 0.25% and 1% of the value of your fund."
    },
    "deferredsalescharge": {
      "title": "Deferred sales charge",
      "definition": "A sales charge when you sell an investment. For mutual funds, these charges are also called back-end loads. For annuities and life insurance policies, these charges are also called surrender charges."
    },
    "load": {
      "title": "Load",
      "definition": "A transaction fee, stated as a percentage of your investment, that you pay when you buy or redeem shares of a mutual fund."
    },
    "redemption": {
      "title": "Redemption",
      "definition": "The act of you selling back your investment to the company that issued the investment."
    },
    "dividends": {
      "title": "Dividends",
      "definition": "A distribution of profits that companies and mutual funds make to shareholders. Dividends are taxed as long-term capital gains and are often paid to shareholders on a quarterly basis."
    },
    "capgain": {
      "title": "Capital gain",
      "definition": "An increase in the value of a capital asset that you own. The IRS defines a capital asset as almost everything you use for personal purposes or investment, including stocks and bonds, your home, personal property, and collectibles."
    },
    "growthratedividends": {
      "title": "Expected rate of growth in dividends",
      "definition": "Enter the annual rate of increase you predict for dividends. By definition, this figure will be much higher for an income fund than a growth fund."
    },
    "operatingexpenseratio": {
      "title": "Operating expense ratio",
      "definition": "The yearly cost, stated as a percentage of fund assets, that you pay a mutual fund. A fund's operating expenses include a yearly management fee paid to the investment adviser, 12(b)-1 marketing and distribution fees, and any other miscellaneous fees."
    },
    "frontendload": {
      "title": "Front-end load",
      "definition": "A fee you pay when you buy shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are investing."
    },
    "brokeragecommission": {
      "title": "Brokerage commission",
      "definition": "The fees that you pay a broker to buy or sell stocks, bonds, or other securities. They are also called transaction fees, trading fees, brokerage fees, or simply, commissions."
    }
  },
  "help": [
    {
      "textLabel": "This tool calculates the impact of <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#brokerageCommission\">brokerage fees</a></span>, <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#load\">loads</a></span> and fund operating expenses on a mutual fund's <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#investReturn\">investment returns</a></span>. Returns are shown before and after taxes. All of these expenses, as well as taxes, drag down a fund's investment return."
    },
    {
      "textLabel": "You pay brokerage fees when you buy and sell shares of a mutual fund. A <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#frontEndLoad\">front-end load</a></span> is paid when you buy the shares. A <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#backEndLoad\">back-end load</a></span> (also called a <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#deferredSalesCharge\">deferred sales charge</a></span>) is paid when you <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#redemption\">redeem</a></span> shares. Funds typically levy one or the other but not both. A <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#noLoadMutualFund\">no-load</a></span> mutual fund does not charge either a front-end or a back-end load."
    },
    {
      "textLabel": "Fund operating expenses include <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#fees12B1\">12(b)-1 fees</a></span> and are paid annually from the assets of the mutual fund. Operating expenses for many mutual funds typically range from 1.00 to 1.75 percent of fund assets each year. This ratio is called a fund's <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#operatingExpenseRatio\">operating expense ratio</a></span>."
    }
  ],
