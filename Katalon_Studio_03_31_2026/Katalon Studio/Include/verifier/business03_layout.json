  "glossaryItems": {
    "costofcapital": {
      "title": "Cost of capital",
      "definition": "The weighted-average cost of debt and equity financing; or the required rate of return a business expects to earn on its investments. Cost of capital is used to discount future cash flows to present value. "
    },
    "paymentbus04": {
      "title": "Monthly payment",
      "definition": "Enter the amount of your monthly payment (Note: if the loan is partially repaid, the loan payment cannot be determined without a loan term.)"
    },
    "loanratebus04": {
      "title": "Interest rate",
      "definition": "Interest rate on the loan is assumed to be a fixed rate until maturity."
    },
    "aftertaxinterestratebus04": {
      "title": "After-tax interest rate",
      "definition": "The after-tax interest rate is the interest rate on a loan after you deduct tax expense. For example, if your loan rate is 6% and your income tax rate is 25%, your after-tax interest rate is 4.5%."
    },
    "addpaymentbus04": {
      "title": "Additional principal payment",
      "definition": "Enter the additional payment you intend to make. The full amount is applied toward reduction of loan principal."
    }
  },
  "help": [
    {
      "textLabel": "<b></b>"
    },
    {
      "textLabel": "This tool shows the amount of time it takes to repay a loan. If you make <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#AddPaymentBus04\">additional principal payments</a></span>, you shorten the repayment period. You also reduce interest expense. Generally, you make prepayments if you have surplus cash or if your current <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#CostofCapital\">cost of capital</a></span> is lower. Since interest expense is tax-deductible, the <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#AfterTaxInterestRateBus04\">after-tax interest</a></span> rate should be considered when making a prepayment decision."
    }
  ],
