  "glossaryItems": {
    "bondprice": {
      "title": "Bond price",
      "definition": "The current price of a bond in the market, as determined by supply and demand. Bond prices are usually stated as a percentage of their face value. For example, a $1,000 bond that is quoted at a price of 98.00 trades at $980."
    },
    "facevalue": {
      "title": "Face value",
      "definition": "The stated, or nominal, price of a bond or fixed deposit, such as a CD, when it matures. Also known as par value."
    },
    "currentyield": {
      "title": "Current yield",
      "definition": "A bond's coupon rate divided by its current price."
    },
    "bondtypes": {
      "title": "Bond types",
      "definition": "The four major types of bonds, as defined by category of issuers, are U.S. government, corporate, agency, and municipal bonds. U.S. government bonds include U.S. Treasury securities. Corporate bonds include those sold by private companies to raise funds. Agency bonds include those sold by government-sponsored enterprises, such as Ginnie Mae, Fannie Mae, and Freddie Mac. Municipal bonds include those sold by state and local governments."
    },
    "couponrate": {
      "title": "Coupon rate",
      "definition": "The interest rate on a bond, stated as a percentage of the bond's face value. For example, a $1,000 bond that pays $60 in interest a year has a coupon rate of 6%."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "treasurysecurities": {
      "title": "Treasury securities",
      "definition": "Debt obligations of the U.S. government with a maturity of longer than 10 years. Also called a T-bond."
    },
    "corporatebonds": {
      "title": "Corporate bond",
      "definition": "Bonds issued by corporations to raise money for operations."
    },
    "munibonds": {
      "title": "Municipal bond",
      "definition": "States and municipalities issue municipal bonds, or muni bonds for short. Investors often buy muni bonds issued by the state or municipality in which they reside to derive the greatest income tax benefit."
    }
  },
  "help": [
    {
      "textLabel": "This tool computes the current yield of a bond, before and after taxes. Current yield equals the bond's annual interest payment divided by the bond's current price. Depending on the type of bond owned, the taxes applied might vary."
    }
  ],
