    "chartIncome": "Income"
  },
  "glossaryItems": {
    "incomefund": {
      "title": "Income fund",
      "definition": "An income fund is a mutual fund that invests in income stocks. Income stocks are the stocks of companies that focus on paying steady or increasing dividends to shareholders."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "growthfund": {
      "title": "Growth fund",
      "definition": "A mutual fund that invests in growth stocks, or stocks of companies that focus on increasing revenues and earnings. Growth stocks tend to not pay dividends and tend to have higher volatility than income or value stocks, making them riskier investments."
    },
    "annualizedreturn": {
      "title": "Annualized rate of return",
      "definition": "An annualized rate of return converts to an annual percentage rate the rate of return that you earn on an investment held for more or less than one year, allowing you to compare investment performance for the same period of time."
    },
    "backendload": {
      "title": "Back-end load",
      "definition": "A fee you pay when you sell shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are selling."
    },
    "growthstock": {
      "title": "Growth stock",
      "definition": "The stock of a company that focuses on increasing revenues and earnings. Growth stocks tend to not pay dividends. Instead, they retain any earnings and invest them in additional growth opportunities. Growth stocks tend to have higher volatility than income or value stocks, making them riskier investments."
    },
    "growthratedividends": {
      "title": "Expected rate of growth in dividends",
      "definition": "Enter the annual rate of increase you predict for dividends. By definition, this figure will be much higher for an income fund than a growth fund."
    },
    "incomestock": {
      "title": "Income stock",
      "definition": "The stock of a company that focuses on paying steady or increasing dividends to shareholders. Income stocks tend to have lower volatility than growth stocks, making them less-risky investments."
    },
    "rateofreturn": {
      "title": "Rate of return",
      "definition": "The percentage gain or loss on an investment expressed as a yearly rate."
    },
    "dividends": {
      "title": "Dividends",
      "definition": "A distribution of profits that companies and mutual funds make to shareholders. Dividends are taxed as long-term capital gains and are often paid to shareholders on a quarterly basis."
    },
    "capgain": {
      "title": "Capital gain",
      "definition": "An increase in the value of a capital asset that you own. The IRS defines a capital asset as almost everything you use for personal purposes or investment, including stocks and bonds, your home, personal property, and collectibles."
    },
    "frontendload": {
      "title": "Front-end load",
      "definition": "A fee you pay when you buy shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are investing."
    }
  },
  "help": [
    {
      "textLabel": "This tool compares <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#rateOfReturn\">rates of return</a></span>, before and after taxes, for a growth and income fund."
    },
    {
      "textLabel": "A <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#growthFund\">growth fund</a></span> invests in <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#growthStock\">growth stocks</a></span>, which are stocks of companies that are expected to grow faster than most companies, as measured by revenues. Growth companies tend not to pay <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#dividends\">dividends</a></span>, retaining any profits to invest in further growth opportunities."
    },
    {
      "textLabel": "An <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#incomeFund\">income fund</a></span> invests in <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#incomeStock\">income stocks</a></span>, which are stocks of companies that pay steady or increasing dividends to shareholders."
    },
    {
      "textLabel": "Mutual fund returns are <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#annualizedReturn\">annualized</a></span>, which means that returns for holding periods of more or less than one year are stated as a yearly percentage."
    }
  ],
  "chartTitles": [
    {
      "title": "Column chart of the return for the growth fund and income fund, before and after taxes."
    }
  ],
  "tableTitles": [
