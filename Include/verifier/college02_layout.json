  "glossaryItems": {
    "estannualcostaddyrclg02": {
      "title": "Estimated annual cost",
      "definition": "Enter your estimate of the total cost for each year of further education."
    },
    "educationlevelcollege02": {
      "title": "Highest education level completed",
      "definition": "Enter the highest education level that you or the person has completed."
    },
    "noaddyrsclg02": {
      "title": "Number of additional years",
      "definition": "Enter the number of years required to attain the desired level of education."
    },
    "estannualincreaseearnings": {
      "title": "Your estimated annual increase in earnings",
      "definition": "The annual percentage rate at which you expect your future earnings to grow. As a rule, earnings typically grow at a rate that is close to the annual rate of inflation. Inflation has averaged between 2 and 3 percent over the last 10 years."
    },
    "currentagecollege02": {
      "title": "Current age",
      "definition": "Enter your current age or the age of the person for whom you are doing the calculation."
    },
    "desirededucationlevelcollege02": {
      "title": "Education level you wish to attain",
      "definition": "Select the level of higher education that you wish to attain."
    },
    "aveexpectedearningscollege02": {
      "title": "Average expected earnings",
      "definition": "According to The College Board, the median annual earnings for a person in 2021 by education level was as follows: high school dropouts ($35,800), high school diploma ($44,300), associate degree ($52,100), bachelor degree ($73,700), a master degree ($87,300)."
    },
    "estannearningsopportcost": {
      "title": "Estimated annual earnings",
      "definition": "Enter your estimate of how much you will earn each year that you are investing in further education."
    },
    "inflation": {
      "title": "Inflation",
      "definition": "A general increase in prices that you pay for goods and services, stated as a yearly rate. "
    },
    "estannualcollegeexpinflationrate": {
      "title": "Estimated inflation rate",
      "definition": "Enter the annual rate that you think the total cost of education will increase while you pursue further education."
    },
    "estannearningspostgrad": {
      "title": "Estimated annual earnings after graduation",
      "definition": "According to The College Board, the median annual earnings for a high school graduate in 2021 were $44,300. (For non-graduates, average earnings were $35.800.) For persons with an associate degree, average earnings were $52,100. For persons with a bachelor degree, average earnings were $73.700. For persons with a master degree, average earnings were $87,300. For more data, see the Web site of The College Board."
    }
  },
  "help": [
    {
      "textLabel": "This tool shows how pursuing a higher education may pay off financially during your earning lifetime. If you already have a college degree, furthering your education with an advanced degree may also pay off financially. The tool does not factor in additional taxes you owe on higher incomes, or higher retirement and Social Security benefits that usually accompany higher earnings."
    }
  ],
