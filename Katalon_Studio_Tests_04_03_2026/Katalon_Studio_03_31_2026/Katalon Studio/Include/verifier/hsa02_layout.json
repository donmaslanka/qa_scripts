  "help": [
    {
      "textLabel": "This tool compares two health plans to help you evaluate which is the more cost effective. If one or both of the plans is an HSA plan, the deductible counts against the out-of-pocket maximums."
    },
    {
      "textLabel": "You can learn more about health savings accounts at the IRS web site. For IRS help concerning health savings accounts, refer to <a target=\"_blank\" href=\"https://www.irs.gov/publications/p969\">IRS Publication 969</a> and <a target=\"_blank\" href=\"https://www.irs.gov/publications/p502\">IRS Publication 502</a>."
    }
  ],
