  "labels": {
    "amount": "Amount",
    "title": "How much should I budget for college living expenses?",
    "answer": "You should budget a total of <span class='lf-bold'>%totalExpenses%</span>, or <span class='lf-bold'>%monthlyExpense%</span> for <span class='lf-bold'>%months%</span> months",
    "selectors": [
      {
        "label": "College Living Expenses",
        "width": "100%",
        "first": true,
        "getGraphData": true
      }
    ],
    "educational": "Educational",
    "communications": "Communications",
    "personal": "Personal",
    "transportation": "Transportation",
    "insurance": "Insurance & Misc"
  },
  "glossaryItems": {
    "labfees": {
      "title": "Lab & other fees",
      "definition": "Enter your estimate of annual expenses for laboratory fees, supplies,  or other expenses that are not included in tuition, room and board, or fees that you pay when you register for school."
    },
    "otherexpenses": {
      "title": "Other expenses",
      "definition": "Enter your estimated  monthly average for expenses not entered elsewhere in this analyzer."
    },
    "transportationexpenses": {
      "title": "Transportation and travel expenses",
      "definition": "Enter the amount you spend monthly, on average, for transportation expenses. If you own a car, your monthly expenses include fuel, repairs, and loan payments. You can leave out the depreciation expense. If you buy a bike with cash, divide the purchase price by the number of months in the school year. If you ride the bus or other form of mass transit, enter the cost of a monthly pass. If you travel to and from school to visit family, add the average monthly cost of this travel to your total monthly transportation expense."
    },
    "foodexpense": {
      "title": "Food",
      "definition": "In case you live off campus or do not use a meal plan, you can use this analyzer to calculate your food expenses. Enter your estimated monthly average bill for food."
    },
    "personalandhouseholdexpenses": {
      "title": "Personal and household-item expenses",
      "definition": "Enter the amount you spend monthly, on average, for personal and household items. Exclude food, clothing, laundry, cell phone, and Internet expenses. Examples of expenses to include: cosmetics, personal-hygiene items, linens, and cleaning products."
    },
    "healthinsuranceexpense": {
      "title": "Health insurance",
      "definition": "Enter your estimated monthly premium for student health insurance. The student health office of your college or university may offer competitively priced premiums."
    },
    "numberofmonths": {
      "title": "Number of months",
      "definition": "Enter the number of months that you wish to compare living costs. If you sign a lease rental agreement, you may want to compare costs over the longer of the two periods. A lease generally obligates you to pay rent for a certain period."
    },
    "ispexpenses": {
      "title": "Internet service (ISP) expenses",
      "definition": "Enter the amount you spend monthly for Internet service. Internet service may be provided by your cable, telephone, or satellite provider or may alternatively be offered by an independent Internet Service Provider (ISP)."
    },
    "entertainmentexpenses": {
      "title": "Entertainment expenses",
      "definition": "Enter the amount you spend monthly, on average, for entertainment expenses such as shows, movies, sports events, and beer."
    }
  },
  "help": [
    {
      "textLabel": "This tool helps you to budget for living expenses for one year of college. To help pay for these expenses, you may wish to consider taking a part-time job, or obtaining an additional amount of financial aid. Most sources of financial aid and tax-advantaged college savings plans consider living expenses a legitimate education-related expense. "
    }
  ],
  "chartTitles": [
    {
      "title": "Pie chart of the breakdown of total annual college living expenses by category."
    }
  ],
  "tableTitles": [
    {
      "title": "Breakdown of total monthly college living expenses by category"
    }
  ]
