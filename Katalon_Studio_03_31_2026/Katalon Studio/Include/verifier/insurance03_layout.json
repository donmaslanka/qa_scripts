  "glossaryItems": {
    "surrendercharge": {
      "title": "Surrender charge",
      "definition": "A fee that you pay to cancel a life insurance policy or annuity contract. Also called a deferred sales charge or back-end load."
    },
    "cashvalue": {
      "title": "Cash value",
      "definition": "A dollar value that is returned to an insurance policyholder if the policy is canceled."
    },
    "taxrates": {
      "title": "Tax rates",
      "definition": "The percentage of your taxable income that is owed to the state and federal governments. The tax rate increases as the taxable base amount increases. "
    },
    "deathbenefit": {
      "title": "Death benefit",
      "definition": "An amount that is paid to the beneficiary of a life insurance policy upon the death of the insured. The amount may be a lump sum or an annuity."
    }
  },
  "help": [
    {
      "textLabel": "This tool compares rates of return for a universal life insurance policy for three periods:"
    },
    {
      "textLabel": "Between the time you acquired the policy and now."
    },
    {
      "textLabel": "Between the time you acquired the policy and the time that you receive full cash value for the policy."
    },
    {
      "textLabel": "Between the time you acquired the policy and the time you die."
    },
    {
      "textLabel": "Rate of return is based on the policy amount, dividends received, policy premiums, and tax rates."
    },
    {
      "textLabel": "Universal life insurance, together with whole and variable life, are cash-value insurance policies, since they earn an investment rate of return and can be used as collateral for loans."
    },
    {
      "textLabel": "Universal life insurance policies pay a death benefit to your beneficiary when you die. Policy coverage continues as long as you pay premiums. Your premium is based on actuarial statistics for your age and health characteristics."
    },
    {
      "textLabel": "While your policy is in effect, it accrues a cash value, which can be used as collateral at an interest rate stated in the policy agreement. Any loans that are outstanding at the time of your death reduce the amount of the death benefit."
    },
    {
      "textLabel": "If you cancel a universal life policy, you are sometimes faced with a surrender charge, particularly if the policy is held for only a short time. A key feature of universal life insurance policies is that the premium can be skipped if the insurer's investment performance is good enough to fund your premium payment."
    }
  ],
