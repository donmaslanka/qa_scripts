  "labels": {
    "title": "What is my debt-to-Income (DTI) ratio?",
    "answer": "<h2 class='lf-graph-text'>Based on a gross monthly income of <span class='lf-bold'>$%result1%</span> and a total of <span class='lf-bold'>$%result2%</span> in recurring monthly debts <span class='lf-bold'>your estimated DTI ratio is %result3%%</span></h2>",
