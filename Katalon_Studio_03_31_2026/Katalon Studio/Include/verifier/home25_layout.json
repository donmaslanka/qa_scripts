  "glossaryItems": {
    "OtherMonthlyPayments": {
      "title": "Other monthly payments",
      "definition": "Include any recurring payments related to maintenance, property management, utility bills, etc."
    }
  },
  "help": [
    {
      "textLabel": "The housing ratio, or \"front-end ratio\", measures the amount of your total monthly housing payment (including principal, interest, property taxes, homeowners insurance, mortgage insurance, and HOA fees) as a percentage of your monthly gross income. The housing ratio is one of two ratios, the other being the debt-to-income ratio, commonly used by lenders to determine whether a mortgage applicant can afford a mortgage loan. Lenders typically prefer to see a housing ratio of 28% or less."
    }
  ],
