  "glossaryItems": {
    "furniture": {
      "title": "Furniture",
      "definition": "Examples include beds, sofas, tables, chairs, dressers, mattresses, entertainment centers, desks, and bookcases."
    },
    "appliances": {
      "title": "Appliances",
      "definition": "Examples include washers, dryers, refridgerators, stoves, dishwashers, freezers, microwaves, coffee makers, toasters, and blenders."
    },
    "electronics": {
      "title": "Electronics",
      "definition": "Examples include TVs, stereos, laptops, tablets, smartphones, smartwaches, cameras, home theater systems, virtual assistants, and video game consoless."
    },
    "jewelry": {
      "title": "Jewelry",
      "definition": "Examples include rings, necklaces, earrings, bracelets, pendants, watches, and cufflinks."
    },
    "homedecorandlinens": {
      "title": "Home décor and linens",
      "definition": "Examples include artwork, window dressings, lamps, plants, bedding, pillows, blankets, towels, and tablecloths."
    },
    "kitchenwares": {
      "title": "Kitchen wares",
      "definition": "Examples include pots, pans, dishes, glassware, silverware, fine china, cooking utensils, and bakeware."
    },
    "media": {
      "title": "Media",
      "definition": "Examples include books, music, movies, and games."
    },
    "yardandgardentools": {
      "title": "Yard and garden tools",
      "definition": "Examples include lawn mowers, blowers, edgers, hedge trimmers, and gardening tools."
    }
  },
  "help": [
    {
      "textLabel": "Homeowners and renters insurance policies provide coverage that can compensate you for personal items such as furniture, clothing and electronics that are damaged in a covered loss, such as theft or fire. As a starting point, use this tool to estimate how much personal property coverage you require based on the approximate value of all your belongings. For further information, please consult an insurance professional."
    }
  ],
  "chartTitles": [
