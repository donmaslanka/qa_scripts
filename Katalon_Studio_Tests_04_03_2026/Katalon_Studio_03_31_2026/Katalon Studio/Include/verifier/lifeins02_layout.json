  "glossaryItems": {
    "premium": {
      "title": "Premium",
      "definition": "Insurance: The amount an insurance policyholder pays periodically to maintain insurance coverage. Premium: A price more than the face value of the bond."
    },
    "cashvalue": {
      "title": "Cash value",
      "definition": "A dollar value that is returned to an insurance policyholder if the policy is canceled."
    },
    "taxrates": {
      "title": "Tax rates",
      "definition": "The percentage of your taxable income that is owed to the state and federal governments. The tax rate increases as the taxable base amount increases. "
    },
    "savingsinterestrate": {
      "title": "Savings interest rate",
      "definition": "The yearly interest rate you earn on your savings."
    },
    "deathbenefit": {
      "title": "Death benefit",
      "definition": "An amount that is paid to the beneficiary of a life insurance policy upon the death of the insured. The amount may be a lump sum or an annuity."
    },
    "dividendsinsurancepolicy": {
      "title": "Dividends (insurance policy)",
      "definition": "A return of insurance premiums to the policyholder. If the investments that an insurance company makes perform better than expected, the insurer returns some of the previously paid premiums."
    }
  },
  "help": [
    {
      "textLabel": "This tool compares rates of return for a whole life insurance policy for three periods: "
    },
    {
      "textLabel": "Between the time you acquired the policy and now."
    },
    {
      "textLabel": "Between the time of purchase and the time the full cash value is received on the policy."
    },
    {
      "textLabel": "Between the time of purchase and the time of death."
    },
    {
      "textLabel": "Rate of return is based on the policy amount, dividends, premiums, and tax rates."
    },
    {
      "textLabel": "Whole life insurance, together with variable and universal life, are cash-value insurance policies, since they earn an investment rate of return and can be used as collateral for loans."
    },
    {
      "textLabel": "Whole life insurance policies pay a death benefit to your beneficiary when you die. Policy coverage continues as long as you pay premiums, which are generally of equal amounts and based on actuarial statistics for your age and health characteristics."
    },
    {
      "textLabel": "While your policy is in effect, it accrues a cash value, which can be used as collateral at an interest rate stated in the policy agreement. Any loans that are outstanding at the time of your death reduce the amount of the death benefit."
    },
    {
      "textLabel": "Whole life policies pay back premiums periodically in the form of tax-exempt dividends. The amount of the dividend generally depends on the performance of the insurance company's investment portfolio."
    },
    {
      "textLabel": "If you cancel a whole life policy, you are sometimes faced with a surrender charge, particularly if the policy is held for only a short time."
    }
  ],
  "chartTitles": [
    {
      "title": "Column chart comparing the after-tax rates of return of the whole life insurance policy if cashed in now, cashed in after a certain number of years, and at death."
    },
