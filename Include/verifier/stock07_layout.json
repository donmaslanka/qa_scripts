  "glossaryItems": {
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "investreturn": {
      "title": "Investment return",
      "definition": "The gain or loss on an investment, stated as an annual percentage rate."
    },
    "dividends": {
      "title": "Dividends",
      "definition": "A distribution of profits that companies and mutual funds make to shareholders. Dividends are taxed as long-term capital gains and are often paid to shareholders on a quarterly basis."
    },
    "capgain": {
      "title": "Capital gain",
      "definition": "An increase in the value of a capital asset that you own. The IRS defines a capital asset as almost everything you use for personal purposes or investment, including stocks and bonds, your home, personal property, and collectibles."
    },
    "growthstock": {
      "title": "Growth stock",
      "definition": "The stock of a company that focuses on increasing revenues and earnings. Growth stocks tend to not pay dividends. Instead, they retain any earnings and invest them in additional growth opportunities. Growth stocks tend to have higher volatility than income or value stocks, making them riskier investments."
    },
    "dividend": {
      "title": "Average quarterly dividends",
      "definition": "Dividends earned on a lot of shares, on average during a quarter."
    },
    "capitalgainstaxes": {
      "title": "Capital gains tax",
      "definition": "Taxes that you owe on capital gains. The capital gains tax rate on assets held for less than a year is the same as if it were ordinary income. For long-term capital gains (assets held for at least one year), the tax rate for single taxpayers is 0% on taxable income up to $48,350, 15% on taxable income between $48,351 and $533,400 and 20% on taxable income over $533,401. For married taxpayers filing jointly, the tax rate is 0% for taxable income up to $96,700, 15% for taxable income between $96,701 and $600,050, and 20% for taxable income over $600,051."
    },
    "savingsinterestrate": {
      "title": "Savings interest rate",
      "definition": "The yearly interest rate you earn on your savings."
    },
    "incomestock": {
      "title": "Income stock",
      "definition": "The stock of a company that focuses on paying steady or increasing dividends to shareholders. Income stocks tend to have lower volatility than growth stocks, making them less-risky investments."
    }
  },
  "help": [
    {
      "textLabel": "This tool compares <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#InvestReturn\">investment returns</a></span>, before and after taxes, for a <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#GrowthStock\">growth</a></span> and <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#IncomeStock\">income stock</a></span>."
    },
    {
      "textLabel": "A growth stock typically earns most of its rate of return from <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#CapGain\">capital gains</a></span>. An income stock typically earns more of its return from <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#Dividends\">dividends</a></span>."
    },
    {
      "textLabel": "Capital gains on assets held for longer than one year and dividends are taxed at a <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#CapitalGainsTaxes\">preferential rate</a></span>."
    },
    {
      "textLabel": "You may wish to consult a financial adviser before making the investment decision."
    }
  ],
