  "glossaryItems": {
    "principal": {
      "title": "Principal",
      "definition": "Also called the loan balance, principal is the amount owed on a loan"
    },
    "taxdeductible": {
      "title": "Tax-deductible",
      "definition": "An item or expense subtracted from adjusted gross income to reduce the amount of income subject to tax."
    },
    "taxsavings": {
      "title": "Tax savings",
      "definition": "The amount you may save in taxes from a tax deduction or tax credit."
    },
    "amortized": {
      "title": "Amortization",
      "definition": "The gradual reduction of loan principal that occurs as you make periodic loan payments."
    },
    "aftertaxinterestrate": {
      "title": "After-tax interest rate",
      "definition": "The after-tax interest rate is the interest rate on a loan after you deduct tax expense. For example, if your loan rate is 6% and your income tax rate is 25%, your after-tax interest rate is 4.5%."
    }
  },
  "help": [
    {
      "textLabel": "This tool helps you determine which of two loans with different terms is the better deal. Generally, a loan with a longer term has a higher interest rate than one with a shorter term. The higher interest rate is to compensate lenders for tying up their funds longer."
    },
    {
      "textLabel": "Since interest expense is <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#TaxDeductible\">tax-deductible</a></span>, the <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#AfterTaxInterestRate\">after-tax interest</a></span> rate should be considered when evaluating a loan. <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#TaxSavings\">Tax savings</a></span> are deducted from total payments to calculate net payments. "
    }
  ],
