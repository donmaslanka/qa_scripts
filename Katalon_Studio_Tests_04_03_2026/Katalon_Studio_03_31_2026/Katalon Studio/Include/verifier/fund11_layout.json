  "labels": {
    "title": "Which is better: front or back load?",
    "answer": "<span class='lf-bold'>%which%</span> will earn a <span class='lf-bold'>higher return</span> after taxes of <span class='lf-bold'>%result%</span>",
    "same_as_answer": "<span class='lf-bold'>Both funds</span> will earn <span class='lf-bold'>the same return</span> after taxes of <span class='lf-bold'>%result%</span>",
    "selectors": [
      {
        "label": "Rate of return",
        "width": "100%",
        "first": true
      }
    ],
    "frontLoad": "Front Load",
    "yAxisLabel": "Return (%)",
    "backLoad": "Back Load",
    "beforeTaxes": "Before Taxes",
    "afterTaxes": "After Taxes"
  },
  "glossaryItems": {
    "rateofreturn": {
      "title": "Rate of return",
      "definition": "The percentage gain or loss on an investment expressed as a yearly rate."
    },
    "mutualfunds": {
      "title": "Mutual fund",
      "definition": "A mutual fund invests in a portfolio of stocks, bonds, or other investments and sells individual shares of the portfolio to investors."
    },
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "dividends": {
      "title": "Dividends",
      "definition": "A distribution of profits that companies and mutual funds make to shareholders. Dividends are taxed as long-term capital gains and are often paid to shareholders on a quarterly basis."
    },
    "capgain": {
      "title": "Capital gain",
      "definition": "An increase in the value of a capital asset that you own. The IRS defines a capital asset as almost everything you use for personal purposes or investment, including stocks and bonds, your home, personal property, and collectibles."
    },
    "annualizedreturn": {
      "title": "Annualized rate of return",
      "definition": "An annualized rate of return converts to an annual percentage rate the rate of return that you earn on an investment held for more or less than one year, allowing you to compare investment performance for the same period of time."
    },
    "backendload": {
      "title": "Back-end load",
      "definition": "A fee you pay when you sell shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are selling."
    },
    "growthratedividends": {
      "title": "Expected rate of growth in dividends",
      "definition": "Enter the annual rate of increase you predict for dividends. By definition, this figure will be much higher for an income fund than a growth fund."
    },
    "frontendload": {
      "title": "Front-end load",
      "definition": "A fee you pay when you buy shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are investing."
    }
  },
  "help": [
    {
      "textLabel": "This tool compares <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#rateOfReturn\">rates of return</a></span>, before and after taxes, for two <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#mutualFunds\">mutual funds</a></span>: a fund that charges a <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#frontEndLoad\">front-end load</a></span> and a fund that charges a <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#backEndLoad\">back-end load</a></span>. Mutual fund returns are <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#annualizedReturn\">annualized</a></span>, which means that returns for holding periods of more or less than one year are stated as a yearly percentage."
    }
  ],
  "chartTitles": [
    {
      "title": "Column chart of the return for the front end fund and back end fund, before and after taxes."
    }
  ],
