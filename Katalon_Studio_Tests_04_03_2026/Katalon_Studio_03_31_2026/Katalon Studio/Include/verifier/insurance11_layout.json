  "labels": {
    "title": "How much car insurance coverage do I need?",
    "answer": "Coverage options and limits:",
    "PER_PERSON": "Per Person",
    "PER_ACCIDENT": "Per Accident",
    "COVERAGE": "Coverage"
  },
  "glossaryItems": {
    "staterequirementscarinsurance": {
      "title": "State requirements for car insurance",
      "definition": "Minimum liability limits vary by state, along with coverage requirements for uninsured/underinsured motorist bodily injury and property damage, personal injury protection and medical payments."
    },
    "carownershipstatus": {
      "title": "Car ownership status",
      "definition": "Financed or leased cars automatically require comprehensive and collision coverage."
    },
    "carvalue": {
      "title": "Car value",
      "definition": "If the value of your car is low, it may not be worth it to purchase comprehensive and collision insurance."
    },
    "financialstate": {
      "title": "Financial state",
      "definition": "If you can pay out-of-pocket to repair or replace your vehicle, you may not need comprehensive and collision coverage."
    },
    "bodilyinjuryliability": {
      "title": "Bodily injury liability",
      "definition": "If you are at fault for a car accident, this insurance coverage helps pay for the medical expenses, lost wages, legal bills for other drivers and passengers. The first amount listed is the maximum an insurance company will pay per injured person. The second amount is the maximum coverage for injury-related expenses per accident. The total of all the bodily injury payouts cannot exceed this amount."
    },
    "propertydamageliability": {
      "title": "Property damage liability",
      "definition": "If you are at fault for a car accident, this insurance coverage helps pay to repair damage you cause to another person's vehicle or property. It does not cover damage to your own vehicle."
    },
    "uninsuredunderinsuredmotoristbodilyinjury": {
      "title": "Uninsured/underinsured motorist bodily injury",
      "definition": "This insurance coverage helps pay you and the people in your car for medical bills, lost wages and pain and suffering if you're in an accident caused by someone who doesn't have insurance or enough insurance. The first amount listed is the maximum an insurance company will pay per injured person. The second amount is the maximum coverage for injury-related expenses per accident. The total of all the bodily injury payouts cannot exceed this amount."
    },
    "uninsuredmotoristpropertydamage": {
      "title": "Uninsured motorist property damage",
      "definition": "This insurance coverage helps pay for damage to your car or other property if you're in an accident caused by someone who doesn't have insurance or enough insurance."
    },
    "personalinjuryprotection": {
      "title": "Personal injury protection",
      "definition": "This coverage, also known as no-fault insurance, covers medical expenses and lost wages of you and your passengers if you're injured in a car accident, regardless of who caused the accident. The first amount listed is the maximum an insurance company will pay per injured person. The second amount is the maximum coverage for injury-related expenses per accident. The total of all the payouts cannot exceed this amount."
    },
    "comprehensiveandcollisioncoverage": {
      "title": "Comprehensive and collision coverage",
      "definition": "Comprehensive car insurance pays for damage to your car caused from things such as theft, fire, or other natural disasters which are not collision-related. Collision insurance covers the cost to repair or replace your car if you're in an accident with another vehicle or object, regardless of who is at fault. Financed or leased cars automatically require comprehensive and collision coverage. If you own your car and either the value is low or you can pay out-of-pocket to repair or replace it, it may not be worth it to purchase comprehensive and collision insurance."
    }
  },
  "help": [
    {
      "textLabel": "This tool serves as an informational starting point to help you determine the right car insurance level and options for your needs. Car insurance laws vary by state. They require different minimum liability limits, and some require uninsured/underinsured motorist coverage and personal injury protection. Those state minimums, however, are typically insufficient to protect you and your car in the event of an accident.  This tool does not represent an actual insurance quote, nor does it present every coverage option or limit available in each state and situation. For further information, please consult an insurance professional."
    }
  ],
