  "glossaryItems": {
    "futuremonthlypayments": {
      "title": "Future monthly payments",
      "definition": "The amount you intend to pay on your credit card balance on a monthly basis. If your payments are less than the interest expense for the period, unpaid interest is added to your card balance. "
    },
    "introrate": {
      "title": "Introductory rate",
      "definition": "The discounted interest rate, sometimes called the teaser rate, you receive during an introductory period of using a new credit card. "
    },
    "futuremonthlycharges": {
      "title": "Future monthly charges",
      "definition": "The net amount you charge on your credit card on a monthly basis, deducting any returns that are credited to your card balance."
    },
    "introperiod": {
      "title": "Introductory period",
      "definition": "The period of an introductory or \"teaser\"; interest rate on a credit card, often lasting three to six months. "
    },
    "rebaterateforbrands": {
      "title": "Rebate rate on rebate card (specific brands)",
      "definition": "The rebate rate on a brand-specific rebate card is the percentage rate at which you can earn rewards using the card on brand-related purchases."
    },
    "rebaterate": {
      "title": "Rebate rate on rebate card",
      "definition": "The rebate rate on a rebate card is the percentage rate at which you can earn rewards using the card. "
    },
    "rebatespecificcardmonthlypurchases": {
      "title": "Monthly amount purchased towards specific-brand rebates",
      "definition": "If you use a rebate card for specific-brand goods, enter the amount of future monthly purchases that are made for those goods. For example, if you expect future monthly charges of $300, and $50 of those charges are for the specific-brand goods, enter $300 as Future monthly charges and $50 as Monthly amount purchased (on the specific-brand goods). Monthly amount purchased is included in Future monthly charges but is entered separately in order to calculate the rebate."
    }
  },
  "help": [
    {
      "textLabel": "This tool compares a rebate reward card with a low interest rate card. Rebate reward cards allow you to accumulate points, or credits, toward merchandise when you make purchases. Often, the reward card comes with a higher annual fee than an ordinary card and may have a higher interest rate. "
    }
  ],
  "chartTitles": [
