  "glossaryItems": {
    "futuremonthlypayments": {
      "title": "Future monthly payments",
      "definition": "The amount you intend to pay on your credit card balance on a monthly basis. If your payments are less than the interest expense for the period, unpaid interest is added to your card balance. "
    },
    "introrate": {
      "title": "Introductory rate",
      "definition": "The discounted interest rate, sometimes called the teaser rate, you receive during an introductory period of using a new credit card. "
    },
    "futuremonthlycharges": {
      "title": "Future monthly charges",
      "definition": "The net amount you charge on your credit card on a monthly basis, deducting any returns that are credited to your card balance."
    },
    "introperiod": {
      "title": "Introductory period",
      "definition": "The period of an introductory or \"teaser\"; interest rate on a credit card, often lasting three to six months. "
    }
  },
  "help": [
    {
      "textLabel": "This tool shows the tradeoff in holding a no-annual fee card with a higher interest rate versus an annual fee card with a lower rate. You may also enter any introductory \"teaser\" rates and the period offered."
    },
    {
      "textLabel": "Your decision depends, in large part, on your card use. If you pay off your balances promptly, you don't incur any card interest expense. There's little reason to pay an annual fee for the privilege of paying the card company promptly. "
    },
    {
      "textLabel": "If you tend to carry a card balance, you should aim to minimize interest expenses by using a low-interest rate card. You may have to pay an annual fee in exchange for the low rate but may save more in interest expense during the year than the cost of the annual fee."
    }
  ],
