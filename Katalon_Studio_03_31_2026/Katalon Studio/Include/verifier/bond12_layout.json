  "glossaryItems": {
    "bondprice": {
      "title": "Bond price",
      "definition": "The current price of a bond in the market, as determined by supply and demand. Bond prices are usually stated as a percentage of their face value. For example, a $1,000 bond that is quoted at a price of 98.00 trades at $980."
    },
    "taxexemptbond": {
      "title": "Tax-exempt bond",
      "definition": "Interest earned on municipal bonds is exempt from federal income taxes. Interest earned on Treasury bonds is exempt from state income taxes. Generally, if an investor is a resident of a state that issues a muni bond, the interest is also exempt from state taxes."
    },
    "facevalue": {
      "title": "Face value",
      "definition": "The stated, or nominal, price of a bond or fixed deposit, such as a CD, when it matures. Also known as par value."
    },
    "couponrate": {
      "title": "Coupon rate",
      "definition": "The interest rate on a bond, stated as a percentage of the bond's face value. For example, a $1,000 bond that pays $60 in interest a year has a coupon rate of 6%."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "taxableequivalentyield": {
      "title": "Taxable-equivalent yield",
      "definition": "The minimum interest rate that an investor must earn on a taxable investment to match his rate of return earned on a tax-exempt security."
    },
    "maturity": {
      "title": "Maturity",
      "definition": "Loans: Maturity is the end of a loan term when the full amount of the loan is repaid in full to the lender. Bonds: Maturity is the date that the face value of the bond is repaid to investors."
    },
    "marketinterestrate": {
      "title": "Market interest rate",
      "definition": "The interest rate for bonds with similar risk characteristics and terms to maturity to those of the bond you are selling."
    }
  },
  "help": [
    {
      "textLabel": "This tool calculates rates of return, before and after taxes, for a taxable and <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#TaxExemptBond\">tax-exempt bond</a></span>. Rates of return are shown for two scenarios: holding the bond to maturity and selling before maturity."
    },
    {
      "textLabel": "Tax-exempt bonds generate a lower rate of return because the interest that they pay is generally exempt from federal (and sometimes state) income taxes. The yield on a taxable bond that is equivalent to the yield on a tax-exempt bond is called the <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#TaxableEquivalentYield\">taxable-equivalent yield</a></span>."
    },
    {
      "textLabel": "Taxable-equivalent yield depends on the investor's income tax rate. For example, an investor in the 25% tax bracket that owns a tax-exempt bond that yields 5% would require a yield of 6.67% on a taxable bond in order to make the taxable bond equally attractive."
    },
    {
      "textLabel": "This tool assumes that the taxable bond is taxed using the regular federal and state taxes, i.e. it is treated as a corporate bond."
    },
    {
      "textLabel": "Depending on the types of bonds being compared, the taxes applied to coupon payments will vary."
    }
  ],
