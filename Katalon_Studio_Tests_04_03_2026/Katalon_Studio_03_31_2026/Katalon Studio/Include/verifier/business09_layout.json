  "glossaryItems": {
    "hdhpwithhsasinglecoveragepremium": {
      "title": "Single coverage HDHP premium",
      "definition": "The monthly premium you pay, per employee, for your High Deductible Health Plan (HDHP) single person coverage."
    },
    "averagehsaemployeecontributionfamily": {
      "title": "Average employee contribution to family coverage HSA",
      "definition": "The portion of the employee's deductible that the employee will be contributing to their Health Savings Account (HSA) with a family coverage High Deductible Health Plan (HDHP)."
    },
    "futastateunemploymentaxrate": {
      "title": "FUTA & state unemployment tax rate",
      "definition": "Under the Federal Unemployment Tax Act (FUTA) employers are required to pay federal and/or state unemployment taxes which are used for unemployment compensation payment to workers who have lost their jobs."
    },
    "averagehsaemployeecontributionsingle": {
      "title": "Average employee contribution to single coverage HSA",
      "definition": "The portion of the employee's deductible that the employee will be contributing to their Health Savings Account (HSA) with a single person coverage High Deductible Health Plan (HDHP)."
    },
    "hdhpwithhsafamilycoveragedeductible": {
      "title": "Family coverage HDHP deductible",
      "definition": "Your deductible for your High Deductible Health Plan (HDHP) family coverage. In 2025, the minimum deductible amount is $3,300 and the maximum out-of-pocket expense is $16,600 for family coverage."
    },
    "averagehsaemployercontributionfamily": {
      "title": "Average employer contribution to family coverage HSA",
      "definition": "The portion of the employee's deductible that the employer will be contributing to their Health Savings Account (HSA) with a family coverage High Deductible Health Plan (HDHP)."
    },
    "hdhpwithhsasinglecoveragedeductible": {
      "title": "Single coverage HDHP deductible",
      "definition": "Your deductible for your High Deductible Health Plan (HDHP) single person coverage. In 2025, the minimum deductible amount is $1,650 and the maximum out-of-pocket expense is $8,300 for self-only coverage."
    },
    "hdhpwithhsafamilycoverageemployees": {
      "title": "Family coverage employees",
      "definition": "How many married employees would participate in the High Deductible Health Plan (HDHP) and Health Savings Accounts (HSA)?"
    },
    "hdhpwithhsafamilycoveragepremium": {
      "title": "Family coverage HDHP premium",
      "definition": "The monthly premium you pay, per employee, for your High Deductible Health Plan (HDHP) family coverage."
    },
    "hdhpwithhsasinglecoverageemployees": {
      "title": "Single coverage employees",
      "definition": "How many single coverage employees would participate in the High Deductible Health Plan (HDHP) and Health Savings Accounts (HSA)?"
    },
    "averagehsaemployercontributionsingle": {
      "title": "Average employer contribution to single coverage HSA",
      "definition": "The portion of the employee's deductible that the employer will be contributing to their Health Savings Account (HSA) with a single person coverage High Deductible Health Plan (HDHP)."
    },
    "singlecoveragenormalpremium": {
      "title": "Traditional health plan single coverage premium",
      "definition": "The monthly premium you pay, per employee, for traditional health insurance single person coverage."
    },
    "familycoveragenormalpremium": {
      "title": "Traditional health plan family coverage premium",
      "definition": "The monthly premium you pay, per employee, for traditional health insurance family coverage."
    },
    "marginaltaxratebusiness": {
      "title": "Income tax rate for business expenses",
      "definition": "The marginal income tax rate for your business."
    }
  },
  "help": [
    {
      "textLabel": "This calculator helps estimate the value of offering a High Deductible Health Plan (HDHP) with Health Savings Accounts (HSA) for your employees. Providing such a plan not only allows your employees to pay for certain medical expenses with money free from federal taxes, it can reduce the premium costs for your business."
    }
  ],
