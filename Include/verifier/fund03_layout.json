  "glossaryItems": {
    "rateofreturn2": {
      "title": "Rate of return",
      "definition": "The percentage gain or loss on an investment expressed as a yearly rate."
    },
    "rateofreturn": {
      "title": "Rate of return",
      "definition": "The percentage gain or loss on an investment expressed as a yearly rate."
    },
    "taxfilingstatus": {
      "title": "Tax filing status",
      "definition": "A category closely tied to marital status that defines the type of tax return form an individual will use."
    },
    "magi": {
      "title": "Modified adjusted gross income (MAGI)",
      "definition": "A measure of income used to determine how much of a tax-deductible contribution you may make to a traditional IRA or nondeductible contribution to a Roth IRA. "
    },
    "dividends": {
      "title": "Dividends",
      "definition": "A distribution of profits that companies and mutual funds make to shareholders. Dividends are taxed as long-term capital gains and are often paid to shareholders on a quarterly basis."
    },
    "capgain": {
      "title": "Capital gain",
      "definition": "An increase in the value of a capital asset that you own. The IRS defines a capital asset as almost everything you use for personal purposes or investment, including stocks and bonds, your home, personal property, and collectibles."
    },
    "growthratedividends": {
      "title": "Expected rate of growth in dividends",
      "definition": "Enter the annual rate of increase you predict for dividends. By definition, this figure will be much higher for an income fund than a growth fund."
    },
    "annualizedreturn": {
      "title": "Annualized rate of return",
      "definition": "An annualized rate of return converts to an annual percentage rate the rate of return that you earn on an investment held for more or less than one year, allowing you to compare investment performance for the same period of time."
    },
    "backendload": {
      "title": "Back-end load",
      "definition": "A fee you pay when you sell shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are selling."
    },
    "frontendload": {
      "title": "Front-end load",
      "definition": "A fee you pay when you buy shares of a mutual fund. The load is calculated as a percentage of the dollar amount you are investing."
    },
    "reinvesting": {
      "title": "Reinvesting",
      "definition": "The act of investing dividends and capital gains that you receive from a company or mutual fund into additional shares of the stock or fund."
    }
  },
  "help": [
    {
      "textLabel": "This tool calculates the price at which you will have to sell shares of a mutual fund to realize your desired <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#rateOfReturn\">rate of return</a></span>. Returns are calculated before and after taxes."
    },
    {
      "textLabel": "The calculator deducts brokerage fees and taxes (for after-tax returns) and calculates your return on an <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#annualizedReturn\">annualized</a></span> basis."
    },
    {
      "textLabel": "<span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#dividends\">Dividends</a></span> and capital gains are <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#reinvesting\">reinvested</a></span> at the specified interest rate or spent. Reinvesting the income you receive on an investment may boost your <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#rateofreturn2\">rate of return</a></span>."
    },
    {
      "textLabel": "You may wish to consult a financial adviser before making the investment decision."
    }
  ],
