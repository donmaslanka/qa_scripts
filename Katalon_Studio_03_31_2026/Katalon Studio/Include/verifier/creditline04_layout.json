  "glossaryItems": {
    "interestrate": {
      "title": "Interest rate",
      "definition": "The amount charged, expressed as a percentage of principal, by a lender to a borrower for the use of money."
    },
    "taxrates": {
      "title": "Tax rates",
      "definition": "The percentage of your taxable income that is owed to the state and federal governments. The tax rate increases as the taxable base amount increases. "
    },
    "term": {
      "title": "Term",
      "definition": "The period of a loan, generally measured in years. Auto loans generally range from 2 to 5 years. Mortgage loans: 15 to 30 years."
    },
    "futureinterestrates": {
      "title": "Future interest rates",
      "definition": "The future interest rate is your prediction of the magnitude of change in the interest rate used to price your loan. Future rates are assumed to change at the same rate every year."
    }
  },
  "help": [
    {
      "textLabel": "This tool calculates monthly payments for an amortizing loan and interest-only payments on a line of credit. "
    },
    {
      "textLabel": "The home equity loan option amortizes the loan balance over the loan term, resulting in a loan payoff at maturity.  The line of credit assumes the user only makes interest payments on the full line of credit.  At the end of the term, the amount owed on the line of credit will be exactly the same as the amount borrowed."
    }
  ],
