  "glossaryItems": {
    "currentretirementsavings": {
      "title": "Current retirement savings",
      "definition": "Total amount that you currently have saved toward your retirement in accounts such as 401(k)s, IRAs and annuities."
    },
    "investmentstyle": {
      "title": "Investment style",
      "definition": "An aggressive investment portfolio is more appropriate for those who have a higher risk tolerance, a longer time horizon, and an appetite for higher returns. Such a strategy would have an asset allocation with a substantial weighting in stocks and possibly little or no allocation to bonds or cash. A conservative investment strategy is best suited for those who have a lower risk tolerance, a shorter time horizon, and a desire for steady returns that prioritize preserving capital. In a conservative investing strategy more than half of a portfolio will generally be held in debt securities and cash equivalents rather than equities or other risky assets."
    },
    "grosshouseholdincome": {
      "title": "Gross household income",
      "definition": "Your pre-tax income income, including your spouse's income, from salary and investments."
    },
    "expectedincomegrowthrate": {
      "title": "Expected income growth rate",
      "definition": "The percentage increase in household income you expect to receive until retirement."
    },
    "retirementcontributionpercentage": {
      "title": "Retirement contribution percentage",
      "definition": "When saving for retirement, most experts recommend an annual retirement savings goal of 10% to 15% of your pre-tax income, including any employer match. This calculator assumes that you make one annual contribution at the end of each year, and any withdrawals happen once per year at the end of the year."
    },
    "retirementspending": {
      "title": "Retirement spending",
      "definition": "Most experts agree that you will need 70-80% of your pre-retirement income to maintain your standard of living in retirement. This amount is based on the household income earned during the year immediately before your retirement. "
    },
    "alternativeretirementincomesources": {
      "title": "Alternative retirement income sources",
      "definition": "Common retirement income sources besides investment accounts, Social Security benefits, and pensions include rental income, reverse mortgage, and part-time work."
    },
    "inflationrate": {
      "title": "Inflation rate",
      "definition": "A general increase in prices that you pay for goods and services, stated as a yearly rate. A common measure of inflation in the U.S. is the Consumer Price Index (CPI)."
    },
    "pension": {
      "title": "Pension",
      "definition": "An employer-sponsored retirement plan that pays retirees a fixed amount that is based on number of years of service and salary history. "
    },
    "maritalstatusandsocialsecurity": {
      "title": "Marital status and Social Security",
      "definition": "Married couples have 1.5 times the maximum Social Security benefit than single wage earners. This calculator assumes that only one spouse works. If you are married and both you and your spouse work, it is recommended that you run the calculation twice - once for each spouse and their respective income. "
    },
    "socialsecurity": {
      "title": "Social Security",
      "definition": "The federal retirement income security program in the U.S. If eligible, you may start receiving benefits when you reach age 62. The minimum age for receiving full benefits is 66 if you were born from 1943 to 1954. The full retirement age increases gradually if you were born from 1955 to 1960 until it reaches 67. For anyone born 1960 or later, full retirement benefits are payable at age 67."
    },
    "lifeexpectancy": {
      "title": "Life expectancy",
      "definition": "Your life expectancy is the number of years that you are expected to live, statistically. Your life expectancy is based on the actual life span of the same set of  population that shares similar risk characteristics. These risk characteristics include smoking and drinking habits, level of exercise, and hereditary or congenital health problems. Life expectancy is used to calculate life insurance premiums and required minimum distributions from IRAs, among other reasons."
    }
  },
  "help": [
    {
      "textLabel": "This tool helps you determine whether you're on track for the retirement you want and map out different paths to reach your target. All projections are hypothetical in nature, do not reflect actual investment results, and are not guarantees of future results. You should consult with your advisor regarding your individual situation."
    },
    {
      "textLabel": "This tool assumes that you make one annual contribution to your retirement savings at the end of each year, and that the year you retire, you do not make any contributions. Any withdrawals during retirement happened once per year at the end of the year."
    }
  ],
