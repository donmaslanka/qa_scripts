  "glossaryItems": {
    "taxableaccount": {
      "title": "Taxable account",
      "definition": "An account that does not receive the tax breaks that either a tax-exempt account or tax-deferred account are eligible to receive. "
    },
    "taxrates": {
      "title": "Tax rates",
      "definition": "The percentage of your taxable income that is owed to the state and federal governments. The tax rate increases as the taxable base amount increases. "
    },
    "taxadvantagedaccount": {
      "title": "Tax-advantaged account",
      "definition": "An investment account with tax-deferred or tax-exempt features that are used to save for retirement, college, and other educational expenses. "
    },
    "annuity": {
      "title": "Annuity",
      "definition": "An insurance policy or an investment that pays out a fixed amount of money each year."
    }
  },
  "help": [
    {
      "textLabel": "This tool helps you determine how much reductions in spending may be worth if you invest the savings. Budget tightening ideas include eating out less, buying fewer clothes, taking fewer trips, waiting to buy a new car, going to fewer movies, brewing coffee at home, paying off credit cards, and carpooling to work, among others."
    },
    {
      "textLabel": "It is assumed that you contribute at the beginning of each month and that you save with a <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#TaxableAccount\">taxable</a></span> account. If you want to simulate saving with a <span class=\"lf-helpTab-tooltip-container\"><a class=\"lf-helpTab-tooltip\" href=\"#TaxAdvantagedAccount\">tax-advantaged</a></span> account, enter a zero in the fields for federal and state income tax rates."
    }
  ],
