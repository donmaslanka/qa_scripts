  "labels": {
    "dataTableCategory": "Total Cost",
    "title": "Should I live on campus, off campus or at home?",
    "answer": "Your most affordable option is to live <span class='lf-bold'>%result%</span>",
    "answer2": "More than one option is the most affordable",
    "selectors": [
      {
        "label": "Expenses by living arrangement",
        "width": "100%",
        "first": true
      }
    ],
    "onCampus": "on campus",
    "offCampus": "off campus",
    "atHome": "at home",
    "chart_onCampus": "On campus",
    "chart_offCampus": "Off campus",
    "chart_atHome": "At home"
  },
  "glossaryItems": {
    "laundryexpenses": {
      "title": "Laundry expenses",
      "definition": "Enter the amount you spend monthly, on average, for laundry and dry cleaning."
    },
    "utilitiesexpense": {
      "title": "Utilities",
      "definition": "In case you live off campus, you can use this analyzer to calculate your rental expenses. Enter your estimated monthly average utility bill amount (electric, gas, or water)."
    },
    "monthlyvehicleinsurancepayment": {
      "title": "Monthly vehicle insurance payment",
      "definition": "Monthly vehicle insurance payment is the amount you pay per month, on average, for insurance for an auto or other vehicle. If you pay an insurance premium less frequently than monthly, divide the billing period by the number of months in the period to calculate a average monthly amount."
    },
    "transportationexpenses": {
      "title": "Transportation and travel expenses",
      "definition": "Enter the amount you spend monthly, on average, for transportation expenses. If you own a car, your monthly expenses include fuel, repairs, and loan payments. You can leave out the depreciation expense. If you buy a bike with cash, divide the purchase price by the number of months in the school year. If you ride the bus or other form of mass transit, enter the cost of a monthly pass. If you travel to and from school to visit family, add the average monthly cost of this travel to your total monthly transportation expense."
    },
    "rentexpense": {
      "title": "Rent",
      "definition": "In case you live off campus, you can use this analyzer to calculate your rental expenses. Enter your monthly rental amount."
    },
    "personalandhouseholdexpenses": {
      "title": "Personal and household-item expenses",
      "definition": "Enter the amount you spend monthly, on average, for personal and household items. Exclude food, clothing, laundry, cell phone, and Internet expenses. Examples of expenses to include: cosmetics, personal-hygiene items, linens, and cleaning products."
    },
    "tvexpenses": {
      "title": "Television expenses",
      "definition": "Monthly expenses for television include subscription fees for cable or satellite TV."
    },
    "numberofmonths": {
      "title": "Number of months",
      "definition": "Enter the number of months that you wish to compare living costs. If you sign a lease rental agreement, you may want to compare costs over the longer of the two periods. A lease generally obligates you to pay rent for a certain period."
    },
    "foodandmeals": {
      "title": "Food and meals",
      "definition": "Enter the amount you spend monthly, on average, for food and meals."
    },
    "securitydeposits": {
      "title": "Security deposits",
      "definition": "Enter amounts of any refundable deposits you are required to pay a landlord, utility, or other vendor when you rent."
    },
    "monthlyvehiclepayment": {
      "title": "Monthly vehicle payment",
      "definition": "Monthly vehicle payment is the amount you pay each month for an auto or other vehicle loan. Enter insurance payments separately."
    },
    "ispexpenses": {
      "title": "Internet service (ISP) expenses",
      "definition": "Enter the amount you spend monthly for Internet service. Internet service may be provided by your cable, telephone, or satellite provider or may alternatively be offered by an independent Internet Service Provider (ISP)."
    },
    "otherexpensescollege10": {
      "title": "Other expenses",
      "definition": "Enter any other expenses that you pay to occupy an apartment or dorm room. These categories include furnishings and the down payment for a vehicle."
    }
  },
  "help": [
    {
      "textLabel": "This tool allows you to budget and compare costs of different living arrangements for you or a child attending college. Living in a dorm or sharing a rental unit near campus with roommates is often an economical way of keeping down living expenses. Another advantage of living close to campus is lower transportation expenses. Living at home may be the cheapest option, but it often involves more spending for transportation."
    }
  ],
  "chartTitles": [
    {
      "title": "Column chart of the total costs of living on campus, living off campus, and living at home."
    }
  ],
  "tableTitles": [
    {
      "title": "Total costs of living on campus, living off campus, and living at home"
    }
  ]
